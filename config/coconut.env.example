# Coconut Configuration — copy to coconut.env and fill in values
# All values are overridable via environment variables

# ── Identity ──────────────────────────────────────────────────────
COCONUT_NAME="Coconut"
COCONUT_TAGLINE="AI Technical Advisor"
COCONUT_EMOJI="🌴"

# ── LLM ───────────────────────────────────────────────────────────
COCONUT_MODEL="claude-haiku-4-5-20251001"
COCONUT_MAX_TOKENS=512
# ANTHROPIC_API_KEY=sk-ant-...  (or set in env / credential store)

# ── Polling ───────────────────────────────────────────────────────
COCONUT_POLL_INTERVAL=3
COCONUT_CACHE_SIZE=50

# ── Adapters (enable one or more) ─────────────────────────────────
# Signal
COCONUT_ADAPTER_SIGNAL_ENABLED=false
COCONUT_SIGNAL_CLI_URL="http://localhost:8080"
COCONUT_SIGNAL_GROUP_ID=""
COCONUT_SIGNAL_PHONE_NUMBER=""

# Teams
COCONUT_ADAPTER_TEAMS_ENABLED=false
COCONUT_TEAMS_CHAT_ID=""
COCONUT_TEAMS_TENANT_ID=""
COCONUT_TEAMS_CLIENT_ID=""
COCONUT_TEAMS_REFRESH_TOKEN=""

# CLI (stdin/stdout — for testing)
COCONUT_ADAPTER_CLI_ENABLED=false

# Webhook (HTTP inbound/outbound — for generic integrations)
COCONUT_ADAPTER_WEBHOOK_ENABLED=false
COCONUT_WEBHOOK_PORT=8000
COCONUT_WEBHOOK_PATH="/webhook/inbound"
COCONUT_WEBHOOK_SECRET=""
COCONUT_WEBHOOK_CALLBACK_URL=""

# ── Persona ───────────────────────────────────────────────────────
COCONUT_SYSTEM_PROMPT_FILE="config/system-prompt.md"

# ── Task Routing (RELAY classification) ───────────────────────────
COCONUT_RELAY_ENABLED=false
COCONUT_RELAY_URL=""
COCONUT_RELAY_TOKEN=""
